# Backend base URL (Spring Boot)
# You MAY include a path prefix if your backend runs under a context-path, e.g. http://localhost:8081/api
PLANNING_BACKEND_URL=http://localhost:8081

# Extraction endpoint path on the backend
# This path is appended to PLANNING_BACKEND_URL (including any base prefix path).
PLANNING_EXTRACT_PATH=/students/planning/parse

# Optional public API base URL used by auth and API client modules.
# If omitted, PLANNING_BACKEND_URL is used.
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8081

# Optional auth endpoint path overrides.
# NEXT_PUBLIC_AUTH_STUDENT_SIGNUP_PATH=/students/auth/signup
# NEXT_PUBLIC_AUTH_STUDENT_SIGNIN_PATH=/students/auth/signin
# NEXT_PUBLIC_AUTH_ADMIN_SIGNUP_PATH=/admins/auth/signup
# NEXT_PUBLIC_AUTH_ADMIN_SIGNIN_PATH=/admins/auth/signin

# Option A: send an Authorization header to the backend (recommended if your endpoint is secured)
# Examples:
# PLANNING_BACKEND_AUTHORIZATION=Bearer <token>
# PLANNING_BACKEND_AUTHORIZATION=Basic <base64(username:password)>
# PLANNING_BACKEND_AUTHORIZATION=

# Option B: send an API key header to the backend
# PLANNING_BACKEND_API_KEY=<key>
# PLANNING_BACKEND_API_KEY_HEADER=x-api-key
